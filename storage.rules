rules_version = '2';

// ══════════════════════════════════════════════════════════
// BOE 2.0 — Reglas de seguridad de Firebase Storage
// Pegar en: Consola Firebase → Storage → Reglas → Publicar
// ══════════════════════════════════════════════════════════

service firebase.storage {
  match /b/{bucket}/o {

    // Cada usuario solo accede a su propia carpeta
    match /usuarios/{userId}/{resto=**} {
      allow read, delete: if request.auth != null
                          && request.auth.uid == userId;

      // Al subir: máx. 10 MB y solo PDF o imágenes permitidas
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType == 'application/pdf'
                       || request.resource.contentType.matches('image/(png|jpeg|jpg|webp)'));
    }
  }
}
